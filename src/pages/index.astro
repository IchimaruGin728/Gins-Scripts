---
import CatalogGrid from "@/components/CatalogGrid.astro"
import BaseLayout from "@/layouts/BaseLayout.astro"
import { TYPES, filesFor, softwaresForType } from "@/lib/catalog"

const quickLinks = [
  { href: "/widgets", label: "Widgets", icon: "i-ph-app-window" },
  { href: "/modules", label: "Modules", icon: "i-ph-cube" },
  { href: "/scripts", label: "Scripts", icon: "i-ph-terminal-window" },
  { href: "/widgets/scripting", label: "Scripting", icon: "i-ph-article" },
  { href: "/widgets/scriptable", label: "Scriptable", icon: "i-ph-device-mobile" },
  { href: "/widgets/egern", label: "Egern", icon: "i-ph-sparkle" },
  { href: "/scripts/quantumultx", label: "QuantumultX", icon: "i-ph-shield" },
  { href: "/scripts/stash", label: "Stash", icon: "i-ph-stack" },
]
---

<BaseLayout
  title="Gins-Scripts"
  eyebrow="Gins Scripts Catalog"
  heading="Script Hub for Apple Network Tools"
  description="Browse production-ready Widgets, Modules, and Scripts with stable URLs, clean structure, and Cloudflare-native delivery."
>
  <Fragment slot="hero-extra">
    <div class="search">
      <span class="i-ph-magnifying-glass text-[20px] text-ink-soft"></span>
      <span class="ml-3">Try keywords like: “weather”, “qweather”, “transparent widget”</span>
      <span class="ml-auto inline-flex h-9 w-9 items-center justify-center rounded-full bg-primary text-white">
        <span class="i-ph-magnifying-glass"></span>
      </span>
    </div>
    <div class="mt-6 flex flex-wrap justify-center gap-2.5">
      {
        quickLinks.map((link, index) => (
          <a
            class="chip animate-[drift_3.4s_ease-in-out_infinite]"
            href={link.href}
            style={`animation-delay:${index * 0.12}s`}
          >
            <span class={link.icon}></span>
            {link.label}
          </a>
        ))
      }
    </div>
  </Fragment>

  <div class="mt-2 text-center">
    <h2 class="m-0 text-[clamp(34px,5vw,58px)] leading-[1.08] tracking-[-0.03em] font-black text-ink">
      3 categories, 8 software surfaces
    </h2>
    <p class="mx-auto mt-3 max-w-[760px] text-[17px] text-ink-soft">
      URL paths are pre-reserved by type and software, so new releases can be added without breaking existing links.
    </p>
  </div>

  {
    TYPES.map((type) => (
      <>
        <div class="sectiontitle">{type.label}</div>
        <section class="grid">
          {softwaresForType(type.id).map((software) => (
            <CatalogGrid type={type} software={software} files={filesFor(type.id, software.id)} />
          ))}
        </section>
      </>
    ))
  }
</BaseLayout>

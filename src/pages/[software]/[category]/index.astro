---



import BaseLayout from "@/layouts/BaseLayout.astro"
import {
  type CatalogCategory,
  categoriesForSoftware,
  filesFor,
  getCanonicalPath,
  getCategoryPath,
  SOFTWARES,
  type SoftwareId,
} from "@/lib/catalog"

export function getStaticPaths() {
  return SOFTWARES.flatMap((software) =>
    categoriesForSoftware(software.id).map((category) => ({
      params: { software: software.id, category: category.id },
      props: { software, category },
    }))
  )
}

const { software, category } = Astro.props as {
  software: { id: SoftwareId; label: string }
  category: { id: CatalogCategory; label: string; description: string }
}

const items = filesFor(software.id, category.id)
const scriptingProjects = Array.from(
  items
    .reduce((groups, item) => {
      if (!groups.has(item.product)) groups.set(item.product, [])
      groups.get(item.product)?.push(item)
      return groups
    }, new Map<string, typeof items>())
    .entries()
).map(([name, files]) => ({
  name,
  files,
  mainFile: files.find((file) => file.source.endsWith("/index.tsx")) ?? files[0],
}))
---

<BaseLayout
  title={`${software.label} ${category.label} | Gins-Scripts`}
  eyebrow={`${software.label} / ${category.label}`}
  heading={category.label}
  description={`${category.description} Namespace: ${getCategoryPath(software.id, category.id)}`}
>
  {
    software.id === "Scripting" && items.length > 0 ? (
      <section class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {scriptingProjects.map((project) => (
          <section class="card">
            <div class="eyebrow">{software.label} Package</div>
            <h2 class="m-0 mb-2 text-[22px] tracking-[-0.02em]">{project.name}</h2>
            <p class="m-0 break-all font-mono text-[12px] text-ink-soft">
              /packages/Scripting/{project.name}.zip
            </p>

            <div class="mt-4 flex flex-wrap gap-2">
              <a class="actionlink" href={`/packages/Scripting/${project.name}/`}>
                Directory
              </a>
              <a class="actionlink" href={`/packages/Scripting/${project.name}.zip`}>
                ZIP
              </a>
              <a class="actionlink" href={getCanonicalPath(project.mainFile)}>
                Open
              </a>
            </div>

            <ul class="mt-4 grid list-none gap-2 p-0">
              {project.files.map((file) => (
                <li class="grid gap-0.5 rounded-xl border border-white/8 bg-primary-soft/50 px-2.5 py-2">
                  <a class="font-semibold no-underline hover:text-primary" href={getCanonicalPath(file)}>
                    {file.label.replace(`${project.name} `, "")}
                  </a>
                  <span class="break-all text-[12px] text-ink-soft font-mono">{getCanonicalPath(file)}</span>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </section>
    ) : items.length > 0 ? (
      <section class="grid">
        <section class="card">
          <div class="eyebrow">{software.label}</div>
          <h2 class="m-0 mb-3.5 text-[20px] tracking-[-0.02em]">{category.label}</h2>
          <ul class="m-0 grid list-none gap-2.5 p-0">
            {items.map((file) => (
              <li class="grid gap-0.75">
                <a href={getCanonicalPath(file)}>{file.label}</a>
                <span class="break-all text-[12px] text-ink-soft font-mono">{getCanonicalPath(file)}</span>
              </li>
            ))}
          </ul>
        </section>
      </section>
    ) : (
      <div class="empty">Nothing published for {software.label} {category.label} yet.</div>
    )
  }
</BaseLayout>

<style>
  .actionlink {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    background: rgba(139, 92, 246, 0.16);
    padding: 0 11px;
    color: #f2edff;
    font-size: 13px;
    font-weight: 800;
    text-decoration: none;
  }
</style>

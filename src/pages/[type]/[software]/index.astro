---
import BaseLayout from "@/layouts/BaseLayout.astro"
import { TYPES, filesFor, getCanonicalPath, getSoftwarePath, softwaresForType, type CatalogType, type SoftwareId } from "@/lib/catalog"

export function getStaticPaths() {
  return TYPES.flatMap((type) =>
    softwaresForType(type.id).map((software) => ({
      params: { type: type.id, software: software.id },
      props: { type, software },
    }))
  )
}

const { type, software } = Astro.props as {
  type: { id: CatalogType; label: string; description: string }
  software: { id: SoftwareId; label: string }
}

const items = filesFor(type.id, software.id)
---

<BaseLayout
  title={`${software.label} ${type.label} | Gins-Scripts`}
  eyebrow={`${type.label} / ${software.label}`}
  heading={software.label}
  description={`Namespace: ${getSoftwarePath(type.id, software.id)}`}
>
  {
    items.length > 0 ? (
      <section class="grid">
        <section class="card">
          <div class="eyebrow">{type.label}</div>
          <h2 class="m-0 mb-3.5 text-[20px] tracking-[-0.02em]">{software.label}</h2>
          <ul class="m-0 grid list-none gap-2.5 p-0">
            {items.map((file) => (
              <li class="grid gap-0.75">
                <a href={getCanonicalPath(file)}>{file.label}</a>
                <span class="break-all text-[12px] text-ink-soft font-mono">{getCanonicalPath(file)}</span>
              </li>
            ))}
          </ul>
        </section>
      </section>
    ) : (
      <div class="empty">Nothing published for {software.label} under {type.label} yet.</div>
    )
  }
</BaseLayout>

---



import type { CatalogCategoryEntry, CatalogFile, SoftwareEntry } from "@/lib/catalog"
import { getCanonicalPath, getDownloadPath } from "@/lib/catalog"

interface Props {
  software: SoftwareEntry
  category: CatalogCategoryEntry
  files: CatalogFile[]
}

const { software, category, files } = Astro.props
---

<section class="card">
  <div class="mb-3 flex items-start justify-between gap-3">
    <div>
      <div class="eyebrow">{software.label}</div>
      <h2 class="m-0 text-[20px] tracking-[-0.02em]">{category.label}</h2>
    </div>
    <div class="trend" aria-hidden="true">
      <span class="trendbar h-3"></span>
      <span class="trendbar h-5" style="animation-delay:.15s"></span>
      <span class="trendbar h-7" style="animation-delay:.3s"></span>
      <span class="trendbar h-4" style="animation-delay:.45s"></span>
      <span class="trendbar h-6" style="animation-delay:.6s"></span>
    </div>
  </div>
  {
    files.length > 0 ? (
      <ul class="m-0 grid list-none gap-2.5 p-0">
        {files.map((file) => (
          <li class="grid gap-0.75 rounded-xl border border-white/8 bg-primary-soft/50 px-2.5 py-2 transition hover:border-primary/40 hover:bg-primary-soft/80">
            <a
              class="font-semibold no-underline hover:text-primary"
              href={file.software === "Scripting" ? getCanonicalPath(file) : getDownloadPath(file)}
            >
              {file.label}
            </a>
            {
              file.software === "Scripting" ? (
                <span class="break-all text-[12px] text-ink-soft font-mono">{getCanonicalPath(file)}</span>
              ) : (
                <a class="break-all text-[12px] text-ink-soft font-mono" href={getDownloadPath(file)}>
                  {getDownloadPath(file)}
                </a>
              )
            }
          </li>
        ))}
      </ul>
    ) : (
      <div class="empty">Nothing published yet.</div>
    )
  }
</section>
